    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet ocr;\ntry {\n  const rawText = input.choices[0].message.content;\n  ocr = JSON.parse(rawText);\n} catch (e) {\n  ocr = {\n    valor_pago: null,\n    data_pagamento: null,\n    id_transacao: null,\n    status_leitura: 'erro'\n  };\n}\n\nconst setNode = $('03 · Extrair clientPhone e Base').first().json;\n\nreturn [{\n  json: {\n    clientPhone: setNode.clientPhone,\n    imageBase64: setNode.imageBase64,\n    imageMimeType: setNode.imageMimeType,\n    messageId: setNode.messageId,\n    ocr: ocr\n  },\n  binary: {\n    \"data\": {\n      data: setNode.imageBase64,\n      mimeType: setNode.imageMimeType,\n      fileName: `comprovante_${setNode.clientPhone}_${Date.now()}.jpg`\n    }\n  }\n}];"
      },
